# ─── Learn more: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files ───

# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
.pnp
.pnp.js

# ============================================================
# EXPO / REACT NATIVE
# ============================================================
.expo/
dist/
web-build/
expo-env.d.ts
.expo-shared/

# ============================================================
# NATIVE BUILD FOLDERS (generated automatically, no need to commit)
# ============================================================
/ios/
/android/

# ============================================================
# ANDROID SIGNING & KEYS (CRITICAL: NEVER upload)
# ============================================================
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision
*.key
*.pem
*.cert

# ============================================================
# FIREBASE NATIVE CONFIG FILES (contain API keys — never commit)
# ============================================================
google-services.json
GoogleService-Info.plist

# ============================================================
# ENVIRONMENT VARIABLES (CRITICAL: contain API keys & secrets)
# ============================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local

# ============================================================
# EDITOR & OS ARTIFACTS
# ============================================================
.DS_Store
*.orig.*
.vscode/settings.json
.vscode/*.code-workspace
Thumbs.db
desktop.ini
# Temporary Office/Word lock files
~$*

# ============================================================
# WORD / OFFICE / PERSONAL DOCUMENTS (not part of the source code)
# ============================================================
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt
*.pdf

# ============================================================
# METRO & DEBUG
# ============================================================
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*

# ============================================================
# TYPESCRIPT
# ============================================================
*.tsbuildinfo

# ============================================================
# GRADLE (Android build caches)
# ============================================================
.gradle/
.kotlin/
android/build/
android/.gradle/
android/app/build/

# ============================================================
# EAS / EXPO BUILD ARTIFACTS
# ============================================================
*.apk
*.aab
*.ipa

# ============================================================
# LOGS
# ============================================================
*.log
logs/
